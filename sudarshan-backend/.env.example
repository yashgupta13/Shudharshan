# ══════════════════════════════════════════════════════════════════════════════
#  SUDARSHAN – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=SUDARSHAN
DEBUG=false

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Replace with your Supabase connection string.
# asyncpg driver is added automatically if you use the plain postgresql:// scheme.
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_use_a_long_random_hex_string_at_least_64_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or ["*"] for development
CORS_ORIGINS=["http://localhost:3000","https://your-frontend.vercel.app"]
# ── Stream Video API ─────────────────────────────────────────────────────────
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here
