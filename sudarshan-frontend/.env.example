# SUDARSHAN Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL
VITE_API_URL=http://localhost:8000

# WebSocket URL
VITE_WS_URL=ws://localhost:8000

# App name (optional override)
VITE_APP_NAME=SUDARSHAN

# DH Key size (bits) - 2048 recommended
VITE_DH_KEY_SIZE=2048
